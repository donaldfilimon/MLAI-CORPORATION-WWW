{
  "name": "mlai-corporation-www",
  "private": true,
  "version": "1.0.0",
  "packageManager": "bun@1.4.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "bun scripts/generate-sitemap.ts && next build",
    "start": "next start --port 3000",
    "sitemap": "bun scripts/generate-sitemap.ts",
    "clean": "rm -rf .next dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "crawl": "bash scripts/crawl-links.sh",
    "smoke": "bash scripts/smoke-api.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-virtual": "^3.11.2",
    "@tensorflow-models/posenet": "^2.2.2",
    "@tensorflow/tfjs": "^4.22.0",
    "@workos-inc/node": "^9.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "iron-session": "^8.0.4",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "next": "15",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "regl": "^2.1.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
