# ── WorkOS AuthKit ───────────────────────────────────────────────────────────
# Get these from https://dashboard.workos.com → API Keys
WORKOS_API_KEY="sk_..."
WORKOS_CLIENT_ID="client_..."

# ── Session ───────────────────────────────────────────────────────────────────
# A random 32+ char secret used to seal the encrypted session cookie.
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-random-32-char-secret"

# ── App ───────────────────────────────────────────────────────────────────────
# Full URL where the app is deployed (used as OAuth redirect URI base)
APP_URL="https://your-cloudrun-url.run.app"

# Server port (Cloud Run injects PORT automatically)
PORT=3001

# Optional SQLite URL for the Rust 2024 Axum server
DATABASE_URL="sqlite://inquiries.db"

# Optional: where the frontend is served, if different from APP_URL
FRONTEND_URL="https://your-cloudrun-url.run.app"

# ── LLM provider (optional) ───────────────────────────────────────────────────
# Without GEMINI_API_KEY, /api/llm/* returns a safe scaffolded fallback response.
LLM_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# ── Billing (optional) ────────────────────────────────────────────────────────
# Without STRIPE_PAYMENT_LINK, /api/billing/checkout returns 503 with guidance.
BILLING_PROVIDER="manual"
STRIPE_PAYMENT_LINK=""

# Require an enrolled WorkOS MFA factor for admin reads (inquiries, telemetry summary).
# See docs/mfa-workos-runbook.md for the dashboard + rollout steps.
ADMIN_REQUIRE_MFA="false"
